prior(normal(log(2), log(5)), class = Intercept),
prior(normal(log(0), log(5)), class = b),
prior(normal(log(10), log(5)), class = sigma),
prior(normal(log(0), log(2)), class = sd),
prior(lkj(log(4)), class = cor)
)
df_eeg_7 <- df_eeg_7 %>% mutate(c_cloze = log(cloze) - mean(log(cloze)))
